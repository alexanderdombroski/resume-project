---
import Layout from '../components/layout/Layout.astro';
---

<Layout title="Resume Editor - Endless Resume" subtitle="Editor">
  <div class="editor-workspace" id="editor-workspace">
    <!-- Loading overlay -->
    <div class="editor-loading" id="editor-loading">
      <span class="spinner" aria-hidden="true"></span>
      <p>Loading your resume details...</p>
    </div>

    <!-- Error container -->
    <div class="editor-error" id="editor-error" style="display: none;">
      <p class="error-msg" id="error-message">Failed to load resume details.</p>
      <a class="button button-secondary" href="/dashboard">Back to Dashboard</a>
    </div>

    <!-- Main Workspace UI (hidden during load) -->
    <div class="workspace-grid" id="workspace-grid" style="display: none;">
      <!-- Left side: Code Editor Column -->
      <section class="editor-column">
        <div class="editor-panel">
          <div class="panel-header">
            <div class="panel-title-group">
              <span class="status-badge" id="save-status">All changes saved</span>
            </div>
            <div class="panel-actions">
              <button
                type="button"
                id="undo-btn"
                class="panel-btn"
                title="Undo (Ctrl+Z / Cmd+Z)"
                disabled
              >
                ⟲ Undo
              </button>
              <button
                type="button"
                id="redo-btn"
                class="panel-btn"
                title="Redo (Ctrl+Y / Cmd+Shift+Z)"
                disabled
              >
                ⟳ Redo
              </button>
              <button
                type="button"
                id="format-btn"
                class="panel-btn"
                title="Prettify JSON formatting"
              >
                Format
              </button>
              <button type="button" id="save-btn" class="save-btn" title="Save (Ctrl+S / Cmd+S)">
                <span class="save-btn-icon" aria-hidden="true">↑</span>
                <span class="save-btn-label">Save</span>
              </button>
            </div>
          </div>

          <!-- Live syntax status banner -->
          <div class="syntax-banner valid" id="syntax-banner">
            <span class="banner-icon" id="syntax-icon">✓</span>
            <span class="banner-text" id="syntax-message">Valid JSON structure</span>
          </div>

          <!-- Code editor wrapper -->
          <div class="editor-wrapper">
            <textarea
              id="json-editor"
              spellcheck="false"
              autocomplete="off"
              placeholder="Paste or write your resume JSON here..."></textarea>
          </div>

          <!-- Helper insert bar -->
          <div class="insert-bar">
            <span class="insert-label">Insert Section:</span>
            <button type="button" class="insert-btn" data-template="experience">+ Experience</button
            >
            <button type="button" class="insert-btn" data-template="education">+ Education</button>
            <button type="button" class="insert-btn" data-template="skills">+ Skills</button>
            <button type="button" class="insert-btn" data-template="projects">+ Projects</button>
          </div>
        </div>

        <!-- Drag & Drop Section Organizer -->
        <div class="organizer-card" id="organizer-card">
          <div class="organizer-header">
            <h3>Visual Section Organizer</h3>
            <span class="organizer-badge">Drag & Drop to Reorder</span>
          </div>
          <p class="organizer-desc">
            Drag the sections below to instantly rearrange your resume's layout structure.
          </p>
          <div class="organizer-list" id="organizer-list">
            <!-- Dynamic cards -->
          </div>
        </div>

        <!-- Cheat Sheet / Help card -->
        <div class="help-card">
          <h3>JSON Editor Guidelines</h3>
          <p>
            This editor displays all your resume content in a single structured field. You can
            customize the fields, reorder sections, or add new items. The system automatically
            handles layout ordering.
          </p>
          <div class="cheat-grid">
            <div>
              <strong>Sections</strong>
              <code>title</code>, <code>type</code>, <code>items</code>, <code>bullets</code>
            </div>
            <div>
              <strong>Section Items</strong>
              <code>label</code> (role/degree), <code>value</code> (company/school), <code
                >start_date</code
              >, <code>end_date</code>, <code>location</code>, <code>description</code>
            </div>
          </div>
        </div>
      </section>

      <!-- Right side: Print Preview Column -->
      <section class="preview-column">
        <div class="preview-header-bar">
          <h2>Live Print Preview</h2>
          <div class="preview-actions">
            <a
              class="button button-secondary preview-action-btn"
              id="print-resume-link"
              href="#"
              target="_blank"
            >
              Print / Export PDF
            </a>
            <a class="button button-secondary preview-action-btn" href="/dashboard"> Dashboard </a>
          </div>
        </div>
        <div class="preview-scroll-container">
          <article class="resume-sheet" id="preview-sheet">
            <header class="resume-header">
              <h1 id="preview-title">Candidate Name</h1>
              <p class="resume-summary" id="preview-summary">Professional summary goes here...</p>
            </header>
            <div id="preview-sections" class="resume-sections">
              <!-- Rendered dynamic sections -->
            </div>
          </article>
        </div>
      </section>
    </div>
  </div>
</Layout>

<script>
  // Parse ID from URL search params
  const params = new URLSearchParams(window.location.search);
  const resumeId = params.get('id');

  const editorLoading = document.getElementById('editor-loading')!;
  const editorError = document.getElementById('editor-error')!;
  const errorMessage = document.getElementById('error-message')!;
  const workspaceGrid = document.getElementById('workspace-grid')!;
  const organizerList = document.getElementById('organizer-list')!;

  const jsonEditor = document.getElementById('json-editor') as HTMLTextAreaElement;
  const saveStatus = document.getElementById('save-status')!;
  const syntaxBanner = document.getElementById('syntax-banner')!;
  const syntaxIcon = document.getElementById('syntax-icon')!;
  const syntaxMessage = document.getElementById('syntax-message')!;

  const undoBtn = document.getElementById('undo-btn') as HTMLButtonElement;
  const redoBtn = document.getElementById('redo-btn') as HTMLButtonElement;
  const formatBtn = document.getElementById('format-btn') as HTMLButtonElement;
  const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;
  const printResumeLink = document.getElementById('print-resume-link') as HTMLAnchorElement;

  const previewTitle = document.getElementById('preview-title')!;
  const previewSummary = document.getElementById('preview-summary')!;
  const previewSections = document.getElementById('preview-sections')!;

  let lastSavedJsonStr = '';
  let currentParsedData: any = null;
  let isDirty = false;

  // Undo/Redo History Stack Management
  let historyStack: string[] = [];
  let historyIdx = -1;
  const MAX_HISTORY = 100;
  let saveHistoryDebounceTimer: any = null;

  function initHistory(initialValue: string) {
    historyStack = [initialValue];
    historyIdx = 0;
    updateHistoryButtons();
  }

  function updateHistoryButtons() {
    if (undoBtn) undoBtn.disabled = historyIdx <= 0;
    if (redoBtn) redoBtn.disabled = historyIdx >= historyStack.length - 1;
  }

  function pushHistoryState(value: string, force = false) {
    if (historyIdx >= 0 && historyStack[historyIdx] === value) {
      return;
    }

    if (force) {
      if (saveHistoryDebounceTimer) clearTimeout(saveHistoryDebounceTimer);
      executePush(value);
    } else {
      if (saveHistoryDebounceTimer) clearTimeout(saveHistoryDebounceTimer);
      saveHistoryDebounceTimer = setTimeout(() => {
        executePush(value);
      }, 500); // Debounce typing changes
    }
  }

  function executePush(value: string) {
    historyStack = historyStack.slice(0, historyIdx + 1);
    historyStack.push(value);

    if (historyStack.length > MAX_HISTORY) {
      historyStack.shift();
    } else {
      historyIdx++;
    }
    updateHistoryButtons();
  }

  function undo() {
    if (historyIdx > 0) {
      if (saveHistoryDebounceTimer) clearTimeout(saveHistoryDebounceTimer);

      historyIdx--;
      const value = historyStack[historyIdx];
      jsonEditor.value = value;

      validateJson();
      updateHistoryButtons();
    }
  }

  function redo() {
    if (historyIdx < historyStack.length - 1) {
      if (saveHistoryDebounceTimer) clearTimeout(saveHistoryDebounceTimer);

      historyIdx++;
      const value = historyStack[historyIdx];
      jsonEditor.value = value;

      validateJson();
      updateHistoryButtons();
    }
  }

  // Visual Section Organizer Drag & Drop State
  let lastRenderedSectionsStr = '';

  function renderSectionOrganizer(data: any) {
    organizerList.innerHTML = '';

    if (!data.sections || !Array.isArray(data.sections) || data.sections.length === 0) {
      organizerList.innerHTML =
        '<p style="color: #64748b; font-size: 0.825rem; margin: 0.5rem 0; text-align: center;">No sections found in JSON</p>';
      return;
    }

    data.sections.forEach((sec: any, idx: number) => {
      const card = document.createElement('div');
      card.className = 'section-drag-card';
      card.setAttribute('draggable', 'true');
      card.setAttribute('data-index', idx.toString());

      card.innerHTML = `
        <span class="drag-handle" aria-hidden="true">☰</span>
        <span class="section-card-title">${sec.title || 'Untitled Section'}</span>
        <span class="section-card-type">${sec.type || 'custom'}</span>
      `;

      // Drag events
      card.addEventListener('dragstart', (e: DragEvent) => {
        card.classList.add('dragging');
        if (e.dataTransfer) {
          e.dataTransfer.effectAllowed = 'move';
          e.dataTransfer.setData('text/plain', idx.toString());
        }
      });

      card.addEventListener('dragend', () => {
        card.classList.remove('dragging');
        document.querySelectorAll('.section-drag-card').forEach((c) => {
          c.classList.remove('drag-over');
        });
      });

      card.addEventListener('dragover', (e: DragEvent) => {
        e.preventDefault();
        if (e.dataTransfer) e.dataTransfer.dropEffect = 'move';
        card.classList.add('drag-over');
      });

      card.addEventListener('dragenter', (e: DragEvent) => {
        e.preventDefault();
      });

      card.addEventListener('dragleave', () => {
        card.classList.remove('drag-over');
      });

      card.addEventListener('drop', (e: DragEvent) => {
        e.preventDefault();
        card.classList.remove('drag-over');

        const fromIndex = parseInt(e.dataTransfer?.getData('text/plain') || '-1', 10);
        const toIndex = idx;

        if (fromIndex !== -1 && fromIndex !== toIndex) {
          reorderSections(fromIndex, toIndex);
        }
      });

      organizerList.appendChild(card);
    });
  }

  function tryRenderOrganizer(parsedData: any) {
    const currentSectionsStr = JSON.stringify(parsedData.sections || []);
    if (currentSectionsStr !== lastRenderedSectionsStr) {
      renderSectionOrganizer(parsedData);
      lastRenderedSectionsStr = currentSectionsStr;
    }
  }

  function reorderSections(fromIdx: number, toIdx: number) {
    try {
      const parsed = JSON.parse(jsonEditor.value);
      if (!parsed.sections || !Array.isArray(parsed.sections)) return;

      pushHistoryState(jsonEditor.value, true);

      const [movedSection] = parsed.sections.splice(fromIdx, 1);
      parsed.sections.splice(toIdx, 0, movedSection);

      const newValue = JSON.stringify(parsed, null, 2);
      jsonEditor.value = newValue;

      validateJson();
      pushHistoryState(newValue, true);
    } catch {
      alert('Cannot reorder sections while there are JSON formatting errors.');
    }
  }

  // Set print link URL
  if (resumeId) {
    printResumeLink.href = `/print?id=${resumeId}&from=editor`;
  }

  // Helper to format dates
  function formatDate(dateStr: string | null): string {
    if (!dateStr) return '';
    try {
      const date = new Date(dateStr);
      if (isNaN(date.getTime())) return dateStr;
      return date.toLocaleDateString(undefined, { year: 'numeric', month: 'short' });
    } catch {
      return dateStr;
    }
  }

  function formatDateRange(startDate: string | null, endDate: string | null): string {
    const start = startDate ? formatDate(startDate.trim()) : '';
    const end = endDate ? formatDate(endDate.trim()) : 'Present';

    if (start && end) return `${start} — ${end}`;
    return start || endDate || '';
  }

  // Convert API response format to simplified Editor JSON
  function toEditorFormat(apiResume: any) {
    return {
      title: apiResume.title || 'Untitled Resume',
      summary: apiResume.summary || '',
      sections: (apiResume.sections || []).map((sec: any) => {
        const simplifiedSec: any = {
          title: sec.title || 'Untitled Section',
          type: sec.type || null,
        };

        if (sec.items && sec.items.length > 0) {
          simplifiedSec.items = sec.items.map((item: any) => ({
            label: item.label || '',
            value: item.value || '',
            start_date: item.start_date || '',
            end_date: item.end_date || '',
            location: item.location || '',
            description: item.description || '',
          }));
        }

        if (sec.bullets && sec.bullets.length > 0) {
          simplifiedSec.bullets = sec.bullets.map((b: any) => b.content || '');
        }

        return simplifiedSec;
      }),
    };
  }

  // Convert Editor JSON to API PUT payload
  function toApiFormat(editorData: any) {
    return {
      title: editorData.title || 'Untitled Resume',
      summary: editorData.summary ? editorData.summary.trim() : null,
      sections: (editorData.sections || []).map((sec: any, secIdx: number) => {
        const apiSec: any = {
          title: sec.title || 'Untitled Section',
          type: sec.type || null,
          item_order: secIdx + 1,
          items: [],
          bullets: [],
        };

        if (sec.items && Array.isArray(sec.items)) {
          apiSec.items = sec.items.map((item: any, itemIdx: number) => ({
            label: item.label ? item.label.trim() : null,
            value: item.value ? item.value.trim() : null,
            start_date: item.start_date ? item.start_date.trim() : null,
            end_date: item.end_date ? item.end_date.trim() : null,
            location: item.location ? item.location.trim() : null,
            description: item.description ? item.description.trim() : null,
            item_order: itemIdx + 1,
          }));
        }

        if (sec.bullets && Array.isArray(sec.bullets)) {
          apiSec.bullets = sec.bullets.map((bullet: any, bulletIdx: number) => {
            if (typeof bullet === 'string') {
              return {
                content: bullet.trim(),
                item_order: bulletIdx + 1,
              };
            } else if (bullet && typeof bullet === 'object') {
              return {
                content: (bullet.content || '').trim(),
                item_order: bulletIdx + 1,
              };
            }
            return { content: '', item_order: bulletIdx + 1 };
          });
        }

        return apiSec;
      }),
    };
  }

  // Render HTML preview based on JSON data
  function updateLivePreview(data: any) {
    previewTitle.textContent = data.title || 'Untitled Resume';
    if (data.summary && data.summary.trim()) {
      previewSummary.textContent = data.summary;
      previewSummary.style.display = 'block';
    } else {
      previewSummary.style.display = 'none';
    }

    previewSections.innerHTML = '';

    if (data.sections && Array.isArray(data.sections)) {
      data.sections.forEach((section: any) => {
        const sectionEl = document.createElement('section');
        sectionEl.className = 'resume-section';

        const h2 = document.createElement('h2');
        h2.textContent = section.title || 'Untitled Section';
        sectionEl.appendChild(h2);

        // Render section items (e.g. experience/education details)
        if (section.items && Array.isArray(section.items) && section.items.length > 0) {
          const itemsContainer = document.createElement('div');
          itemsContainer.className = 'section-items';

          section.items.forEach((item: any) => {
            const itemEl = document.createElement('div');
            itemEl.className = 'section-item';

            const headerEl = document.createElement('div');
            headerEl.className = 'item-header';

            const labelEl = document.createElement('strong');
            labelEl.className = 'item-label';
            labelEl.textContent = item.label || '';
            headerEl.appendChild(labelEl);

            if (item.value) {
              const valueEl = document.createElement('span');
              valueEl.className = 'item-value';
              valueEl.textContent = item.value;
              headerEl.appendChild(document.createTextNode(' | '));
              headerEl.appendChild(valueEl);
            }

            itemEl.appendChild(headerEl);

            // Dates and location row
            const dateRange = formatDateRange(item.start_date, item.end_date);
            if (dateRange || item.location) {
              const metaEl = document.createElement('div');
              metaEl.className = 'item-meta';

              if (dateRange) {
                const dateEl = document.createElement('span');
                dateEl.className = 'item-date';
                dateEl.textContent = dateRange;
                metaEl.appendChild(dateEl);
              }

              if (item.location) {
                if (dateRange) {
                  metaEl.appendChild(document.createTextNode(' — '));
                }
                const locEl = document.createElement('span');
                locEl.className = 'item-location';
                locEl.textContent = item.location;
                metaEl.appendChild(locEl);
              }

              itemEl.appendChild(metaEl);
            }

            // Description
            if (item.description && item.description.trim()) {
              const descEl = document.createElement('p');
              descEl.className = 'item-description';
              descEl.textContent = item.description;
              itemEl.appendChild(descEl);
            }

            itemsContainer.appendChild(itemEl);
          });

          sectionEl.appendChild(itemsContainer);
        }

        // Render bullet points
        if (section.bullets && Array.isArray(section.bullets) && section.bullets.length > 0) {
          const ul = document.createElement('ul');
          ul.className = 'section-bullets';

          section.bullets.forEach((bullet: any) => {
            const content = typeof bullet === 'string' ? bullet : bullet.content || '';
            if (content && content.trim()) {
              const li = document.createElement('li');
              li.textContent = content;
              ul.appendChild(li);
            }
          });

          sectionEl.appendChild(ul);
        }

        previewSections.appendChild(sectionEl);
      });
    }
  }

  // Validate the text in the JSON editor
  function validateJson(): boolean {
    const value = jsonEditor.value;
    try {
      if (!value.trim()) {
        throw new Error('Editor content is empty.');
      }

      const parsed = JSON.parse(value);
      currentParsedData = parsed;

      // Basic schema checking
      if (typeof parsed !== 'object' || parsed === null) {
        throw new Error('Root elements must be a single JSON object {}.');
      }

      if (parsed.sections !== undefined && !Array.isArray(parsed.sections)) {
        throw new Error('"sections" field must be an array [].');
      }

      // Syntax and structural validation succeeded
      syntaxBanner.className = 'syntax-banner valid';
      syntaxIcon.textContent = '✓';
      syntaxMessage.textContent = 'Valid JSON structure';
      saveBtn.removeAttribute('disabled');

      // Update the side preview in real-time
      updateLivePreview(parsed);

      // Track if there are unsaved changes
      const normalizedCurrent = JSON.stringify(parsed);
      const normalizedLastSaved = lastSavedJsonStr
        ? JSON.stringify(JSON.parse(lastSavedJsonStr))
        : '';

      if (normalizedCurrent !== normalizedLastSaved) {
        isDirty = true;
        saveStatus.textContent = 'Unsaved changes';
        saveStatus.className = 'status-badge unsaved';
      } else {
        isDirty = false;
        saveStatus.textContent = 'All changes saved';
        saveStatus.className = 'status-badge saved';
      }

      // Render section organizer
      tryRenderOrganizer(parsed);
      if (organizerList) organizerList.classList.remove('invalid');

      return true;
    } catch (err: any) {
      syntaxBanner.className = 'syntax-banner invalid';
      syntaxIcon.textContent = '⚠';
      syntaxMessage.textContent = 'Invalid JSON: ' + err.message;
      saveBtn.setAttribute('disabled', 'true');
      if (organizerList) organizerList.classList.add('invalid');
      return false;
    }
  }

  // Save resume changes
  async function saveResume() {
    if (!validateJson()) {
      alert('Please correct JSON formatting errors before saving.');
      return;
    }

    const saveBtnLabel = saveBtn.querySelector('.save-btn-label')!;
    const saveBtnIcon = saveBtn.querySelector('.save-btn-icon')!;

    saveStatus.textContent = 'Saving changes...';
    saveStatus.className = 'status-badge saving';
    saveBtn.setAttribute('disabled', 'true');
    saveBtn.classList.add('is-saving');
    saveBtnIcon.textContent = '↻';
    saveBtnLabel.textContent = 'Saving';

    try {
      const apiPayload = toApiFormat(currentParsedData);

      const response = await fetch(`/api/resume/${resumeId}`, {
        method: 'PUT',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(apiPayload),
      });

      if (response.status === 401) {
        window.location.href = '/?auth=sign-in';
        return;
      }

      if (!response.ok) {
        throw new Error(`Failed to save resume details (status: ${response.status})`);
      }

      // Update check point
      lastSavedJsonStr = JSON.stringify(currentParsedData, null, 2);
      isDirty = false;
      saveStatus.textContent = 'All changes saved';
      saveStatus.className = 'status-badge saved';

      if (currentParsedData.title) {
        document.title = `Edit: ${currentParsedData.title} - Endless Resume`;
      }

      // Briefly show saved confirmation, then reset quietly
      saveBtn.classList.remove('is-saving');
      saveBtn.classList.add('is-saved');
      saveBtnIcon.textContent = '✓';
      saveBtnLabel.textContent = 'Saved';

      setTimeout(() => {
        saveBtn.classList.remove('is-saved');
        saveBtn.removeAttribute('disabled');
        saveBtnLabel.textContent = 'Save';
      }, 1800);
    } catch (err: any) {
      console.error(err);
      saveStatus.textContent = 'Save failed';
      saveStatus.className = 'status-badge error';
      saveBtn.classList.remove('is-saving');
      saveBtn.classList.add('is-error');
      saveBtnIcon.textContent = '!';
      saveBtnLabel.textContent = 'Error';
      saveBtn.removeAttribute('disabled');
      setTimeout(() => {
        saveBtn.classList.remove('is-error');
        saveBtnIcon.textContent = '↑';
        saveBtnLabel.textContent = 'Save';
      }, 3000);
      alert(`Error saving resume: ${err.message}`);
    }
  }

  // Load resume on startup
  async function loadResume() {
    if (!resumeId) {
      editorLoading.style.display = 'none';
      editorError.style.display = 'block';
      errorMessage.textContent = 'Missing resume ID parameter in URL query parameters.';
      return;
    }

    try {
      const response = await fetch(`/api/resume/${resumeId}`);
      if (response.status === 401) {
        window.location.href = '/?auth=sign-in';
        return;
      }
      if (!response.ok) {
        throw new Error(`Failed to fetch resume (status: ${response.status})`);
      }
      const data = await response.json();
      const resume = data.resume;

      if (!resume) {
        throw new Error('Resume not found.');
      }

      // Format to editor structure and prettify
      const editorFormat = toEditorFormat(resume);
      const initialJsonStr = JSON.stringify(editorFormat, null, 2);

      jsonEditor.value = initialJsonStr;
      lastSavedJsonStr = initialJsonStr;
      initHistory(initialJsonStr);
      currentParsedData = editorFormat;

      // Update document title
      document.title = `Edit: ${resume.title} - Endless Resume`;

      // Draw preview layout
      updateLivePreview(editorFormat);

      // Display workspace UI
      editorLoading.style.display = 'none';
      workspaceGrid.style.display = 'grid';

      // Initialize status validation
      validateJson();
    } catch (err: any) {
      console.error(err);
      editorLoading.style.display = 'none';
      editorError.style.display = 'block';
      errorMessage.textContent = `Error loading resume details: ${err.message}`;
    }
  }

  // Add event listeners
  jsonEditor.addEventListener('input', () => {
    validateJson();
    pushHistoryState(jsonEditor.value);
  });

  undoBtn.addEventListener('click', undo);
  redoBtn.addEventListener('click', redo);

  formatBtn.addEventListener('click', () => {
    try {
      const parsed = JSON.parse(jsonEditor.value);
      const formatted = JSON.stringify(parsed, null, 2);
      pushHistoryState(jsonEditor.value, true);
      jsonEditor.value = formatted;
      validateJson();
      pushHistoryState(formatted, true);
    } catch {
      alert('Cannot format invalid JSON. Please resolve syntax errors first.');
    }
  });

  saveBtn.addEventListener('click', saveResume);

  // Keyboard shortcuts (Save, Undo, Redo)
  window.addEventListener('keydown', (e) => {
    // Save: Cmd+S or Ctrl+S
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 's') {
      e.preventDefault();
      saveResume();
    }

    // Undo: Cmd+Z or Ctrl+Z
    if ((e.metaKey || e.ctrlKey) && !e.shiftKey && e.key.toLowerCase() === 'z') {
      e.preventDefault();
      undo();
    }

    // Redo: Cmd+Shift+Z or Ctrl+Y
    if (
      ((e.metaKey || e.ctrlKey) && e.shiftKey && e.key.toLowerCase() === 'z') ||
      ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'y')
    ) {
      e.preventDefault();
      redo();
    }
  });

  // Warn on leave with unsaved modifications
  window.addEventListener('beforeunload', (e) => {
    if (isDirty) {
      e.preventDefault();
      e.returnValue = 'You have unsaved changes. Are you sure you want to leave?';
    }
  });

  // Templates definition
  const TEMPLATES: Record<string, any> = {
    experience: {
      title: 'Experience',
      type: 'experience',
      items: [
        {
          label: 'Software Engineer',
          value: 'Acme Corp',
          start_date: '2024-01-01',
          end_date: 'Present',
          location: 'Remote',
          description: 'Led development of core features and scaled API throughput.',
        },
      ],
      bullets: [
        'Collaborated with cross-functional teams to deliver critical products.',
        'Refactored legacy database models, improving retrieval times by 30%.',
      ],
    },
    education: {
      title: 'Education',
      type: 'education',
      items: [
        {
          label: 'B.S. Computer Science',
          value: 'University of Tech',
          start_date: '2020-09-01',
          end_date: '2024-05-01',
          location: 'Boston, MA',
          description: 'GPA 3.8/4.0. Completed coursework in Algorithms and Databases.',
        },
      ],
    },
    skills: {
      title: 'Skills',
      type: 'skills',
      bullets: [
        'Languages: JavaScript, TypeScript, Python, SQL',
        'Frameworks: React, Next.js, Express, Node.js',
      ],
    },
    projects: {
      title: 'Projects',
      type: 'project',
      items: [
        {
          label: 'E-Commerce Service',
          value: 'TypeScript + Express + Postgres',
          start_date: '2024-02-01',
          end_date: '2024-04-01',
          location: '',
          description: 'Designed and implemented a high-performance checkout microservice.',
        },
      ],
      bullets: [
        'Integrated Stripe payment APIs with webhooks and transactional safety.',
        'Decreased cart abandonment rates by 15% through workflow optimizations.',
      ],
    },
  };

  // Bind insert templates buttons
  document.querySelectorAll('.insert-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const templateName = btn.getAttribute('data-template');
      if (!templateName) return;
      const template = TEMPLATES[templateName];
      if (!template) return;

      try {
        const parsed = JSON.parse(jsonEditor.value);
        if (!parsed.sections) {
          parsed.sections = [];
        }

        pushHistoryState(jsonEditor.value, true);

        parsed.sections.push(template);
        const newValue = JSON.stringify(parsed, null, 2);
        jsonEditor.value = newValue;

        validateJson();
        pushHistoryState(newValue, true);

        jsonEditor.focus();
        // Scroll editor to end
        jsonEditor.scrollTop = jsonEditor.scrollHeight;
      } catch {
        alert('Please fix JSON syntax errors before attempting to insert new sections.');
      }
    });
  });

  // Load the initial data
  loadResume();
</script>

