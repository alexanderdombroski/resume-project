---
import Layout from '../components/layout/Layout.astro';
---

<Layout title="Resume Editor - Endless Resume" subtitle="Editor">
  <section class="editor-stub">
    <div class="editor-card">
      <p class="section-label">Resume Editor</p>
      <h1 id="editor-title">Resume Editor</h1>
      <p class="lede" id="editor-lede">
        This workspace will allow you to edit your resume's content, structure, and targeted
        modifications.
      </p>
      <div class="actions">
        <a class="button button-primary" href="/dashboard">Back to Dashboard</a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const id = new URLSearchParams(window.location.search).get('id');

  if (!id) {
    window.location.replace('/dashboard');
  } else {
    const titleEl = document.getElementById('editor-title')!;
    titleEl.textContent = `Editing Resume #${id}`;
    document.title = `Edit Resume #${id} - Endless Resume`;
  }
</script>

<style>
  .editor-stub {
    display: grid;
    place-items: center;
    min-height: calc(100vh - 12rem);
    padding: 1.5rem 0 2.5rem;
  }

  .editor-card {
    width: min(50rem, 100%);
    padding: clamp(1.35rem, 3vw, 2rem);
    border-radius: 1.5rem;
    background: rgb(255 255 255 / 0.72);
    border: 1px solid rgb(148 163 184 / 0.18);
    box-shadow: 0 24px 70px rgb(15 23 42 / 0.08);
    backdrop-filter: blur(14px);
  }

  .section-label {
    margin: 0 0 0.8rem;
    color: #1d4ed8;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .editor-card h1 {
    margin: 0;
    color: #0f172a;
    font-size: clamp(2rem, 4vw, 3.1rem);
    line-height: 1;
    letter-spacing: -0.06em;
  }

  .lede {
    margin: 1rem 0 0;
    max-width: 46rem;
    color: #475569;
    font-size: 1rem;
    line-height: 1.7;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 1.7rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.15rem;
    padding: 0.85rem 1.25rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
  }

  .button-primary {
    color: #ffffff;
    background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 55%, #2563eb 100%);
    box-shadow: 0 18px 34px rgb(37 99 235 / 0.28);
  }
</style>
