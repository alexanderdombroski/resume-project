---
import Layout from '../components/layout/Layout.astro';
import { SignIn } from '@clerk/astro/components';
---

<Layout title="Sign in - Endless Resume" subtitle="Authentication">
  <section class="auth-page">
    <section class="auth-panel" aria-labelledby="sign-in-title">
      <div class="auth-copy">
        <p class="auth-label">Account access</p>
        <h1 id="sign-in-title">Sign in or create an account</h1>
        <p>
          Use your username or email and password to access the workspace. If you do not have an
          account yet, you can register from the same Clerk form.
        </p>
      </div>

      <div class="auth-card">
        <SignIn
          withSignUp={true}
          fallbackRedirectUrl="/dashboard"
          signUpFallbackRedirectUrl="/dashboard"
        />
      </div>
    </section>
  </section>
</Layout>

<style>
  .auth-page {
    display: grid;
    place-items: center;
    min-height: calc(100vh - 12rem);
    padding: 1.5rem 0 2.5rem;
  }

  .auth-panel {
    width: min(72rem, 100%);
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(320px, 1.1fr);
    gap: 1.5rem;
    align-items: center;
  }

  .auth-copy {
    max-width: 30rem;
  }

  .auth-label {
    margin: 0 0 0.45rem;
    color: #1d4ed8;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .auth-copy h1 {
    margin: 0;
    color: #0f172a;
    font-size: clamp(2.2rem, 5vw, 4.25rem);
    line-height: 0.96;
    letter-spacing: -0.06em;
    text-wrap: balance;
  }

  .auth-copy p:last-child {
    margin: 1rem 0 0;
    color: #475569;
    font-size: 1.02rem;
    line-height: 1.7;
  }

  .auth-card {
    overflow: hidden;
    border-radius: 1.5rem;
    border: 1px solid rgb(148 163 184 / 0.18);
    background: rgb(255 255 255 / 0.82);
    box-shadow: 0 24px 70px rgb(15 23 42 / 0.1);
    backdrop-filter: blur(14px);
    padding: clamp(0.9rem, 2vw, 1.25rem);
  }

  .auth-card :global(form) {
    width: 100%;
  }

  @media (max-width: 880px) {
    .auth-panel {
      grid-template-columns: 1fr;
    }
  }
</style>
