---
import Layout from '../components/layout/Layout.astro';
---

<Layout title="Dashboard - Endless Resume" subtitle="Workspace">
  <section class="dashboard">
    <section class="dashboard-card" aria-labelledby="dashboard-title">
      <p class="section-label">Your Workspace</p>
      <h1 id="dashboard-title">Your resumes</h1>
      <p>
        Welcome back. Here you can manage, update, and tailor your resumes to fit specific job
        descriptions.
      </p>

      <div id="resume-container" aria-live="polite">
        <div class="loading-state" id="resume-loading">
          <span class="spinner" aria-hidden="true"></span>
          <p>Loading your resumes&hellip;</p>
        </div>
      </div>
    </section>
  </section>
</Layout>

<template id="resume-list-tpl">
  <ul class="resume-list" aria-label="Your resumes"></ul>
</template>

<template id="resume-item-tpl">
  <li class="resume-item">
    <div class="resume-copy">
      <p class="resume-kicker"></p>
      <h2></h2>
      <p class="resume-summary"></p>
    </div>
    <div class="resume-meta">
      <span class="resume-created"></span>
      <span class="resume-updated"></span>
    </div>
  </li>
</template>

<template id="empty-state-tpl">
  <div class="empty-state">
    <h2>No resumes found</h2>
    <p>
      You haven't created any resumes yet. Return to the homepage to get started and build your
      first tailored resume.
    </p>
    <div class="actions">
      <a class="button button-primary" href="/">Create a resume</a>
    </div>
  </div>
</template>

<script>
  const container = document.getElementById('resume-container')!;
  const loading = document.getElementById('resume-loading')!;

  async function loadResumes() {
    let data: {
      resumes: Array<{
        id: number;
        title: string;
        summary: string | null;
        createdAt: string;
        updatedAt: string;
      }>;
    };

    try {
      const res = await fetch('/api/resume');

      if (res.status === 401) {
        window.location.href = '/?auth=sign-in';
        return;
      }

      if (!res.ok) {
        throw new Error(`Unexpected response: ${res.status}`);
      }

      data = await res.json();
    } catch {
      loading.innerHTML =
        '<p class="error-msg">Failed to load resumes. Please refresh the page.</p>';
      return;
    }

    loading.remove();

    if (data.resumes.length === 0) {
      const emptyTpl = document.getElementById('empty-state-tpl') as HTMLTemplateElement;
      container.appendChild(emptyTpl.content.cloneNode(true));
      return;
    }

    const listTpl = document.getElementById('resume-list-tpl') as HTMLTemplateElement;
    const itemTpl = document.getElementById('resume-item-tpl') as HTMLTemplateElement;
    const list = listTpl.content.cloneNode(true) as DocumentFragment;
    const ul = list.querySelector('ul')!;

    for (const resume of data.resumes) {
      const item = itemTpl.content.cloneNode(true) as DocumentFragment;
      item.querySelector('.resume-kicker')!.textContent = `Resume #${resume.id}`;
      item.querySelector('h2')!.textContent = resume.title;
      item.querySelector('.resume-summary')!.textContent =
        resume.summary ?? 'No summary added yet.';
      item.querySelector('.resume-created')!.textContent =
        `Created ${new Date(resume.createdAt).toLocaleDateString()}`;
      item.querySelector('.resume-updated')!.textContent =
        `Updated ${new Date(resume.updatedAt).toLocaleDateString()}`;

      const li = item.querySelector('li')!;
      li.addEventListener('click', () => {
        window.location.href = `/editor?id=${resume.id}`;
      });
      li.style.cursor = 'pointer';

      ul.appendChild(item);
    }

    container.appendChild(list);
  }

  loadResumes();
</script>

<style>
  .dashboard {
    display: grid;
    place-items: center;
    min-height: calc(100vh - 12rem);
    padding: 1.5rem 0 2.5rem;
  }

  .dashboard-card {
    width: min(50rem, 100%);
    padding: clamp(1.35rem, 3vw, 2rem);
    border-radius: 1.5rem;
    background: rgb(255 255 255 / 0.72);
    border: 1px solid rgb(148 163 184 / 0.18);
    box-shadow: 0 24px 70px rgb(15 23 42 / 0.08);
    backdrop-filter: blur(14px);
  }

  .section-label {
    margin: 0 0 0.8rem;
    color: #1d4ed8;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .dashboard-card h1 {
    margin: 0;
    color: #0f172a;
    font-size: clamp(2rem, 4vw, 3.1rem);
    line-height: 1;
    letter-spacing: -0.06em;
  }

  .dashboard-card > p {
    margin: 1rem 0 0;
    max-width: 46rem;
    color: #475569;
    font-size: 1rem;
    line-height: 1.7;
  }

  /* Loading */
  .loading-state {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1.75rem;
    color: #64748b;
    font-size: 0.95rem;
  }

  .spinner {
    display: inline-block;
    width: 1.1rem;
    height: 1.1rem;
    border: 2px solid rgb(37 99 235 / 0.2);
    border-top-color: #1d4ed8;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    flex-shrink: 0;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  :global(.error-msg) {
    margin: 1.75rem 0 0;
    color: #dc2626;
    font-size: 0.95rem;
  }

  /* Resume list */
  .resume-list {
    list-style: none;
    margin: 1.75rem 0 0;
    padding: 0;
    display: grid;
    gap: 1rem;
  }

  .resume-item {
    display: grid;
    gap: 1rem;
    padding: 1.15rem 1.15rem 1.05rem;
    border-radius: 1.15rem;
    background: rgb(255 255 255 / 0.78);
    border: 1px solid rgb(148 163 184 / 0.16);
    box-shadow: 0 14px 30px rgb(15 23 42 / 0.05);
    transition:
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  .resume-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 20px 40px rgb(15 23 42 / 0.09);
  }

  .resume-copy h2 {
    margin: 0;
    color: #0f172a;
    font-size: 1.25rem;
    line-height: 1.15;
    letter-spacing: -0.04em;
  }

  .resume-kicker {
    margin: 0 0 0.45rem;
    color: #1d4ed8;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .resume-summary {
    margin: 0.75rem 0 0;
    color: #475569;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .resume-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem 1rem;
    color: #64748b;
    font-size: 0.9rem;
  }

  /* Empty state */
  .empty-state {
    margin-top: 1.75rem;
    padding: 1.25rem;
    border-radius: 1.15rem;
    background: rgb(255 255 255 / 0.68);
    border: 1px solid rgb(148 163 184 / 0.16);
  }

  .empty-state h2 {
    margin: 0;
    color: #0f172a;
    font-size: 1.15rem;
  }

  .empty-state p {
    margin-top: 0.65rem;
    color: #475569;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 1.7rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.15rem;
    padding: 0.85rem 1.25rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
  }

  .button-primary {
    color: #ffffff;
    background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 55%, #2563eb 100%);
    box-shadow: 0 18px 34px rgb(37 99 235 / 0.28);
  }
</style>
