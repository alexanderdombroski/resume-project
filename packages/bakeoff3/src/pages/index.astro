---
import Layout from '../components/layout/Layout.astro';
import Hero from '../components/Hero.astro';
---

<Layout title="Endless Resume" subtitle="Resume Editor">
  <main class="landing">
    <Hero />

    <!-- D3 professional network graph -->
    <section class="network-section" aria-label="Professional network visualisation">
      <div class="network-header">
        <p class="section-label">Your professional orbit</p>
        <h2>Resume tailoring is about connecting the right dots</h2>
        <p class="network-lede">
          Every role you apply to sits inside a network of skills, experience, and context. Drag the
          nodes.
        </p>
      </div>
      <div class="network-canvas-wrap">
        <svg id="network-svg" aria-hidden="true"></svg>
      </div>
    </section>

    <section class="supporting" id="how-it-works">
      <div class="supporting-card" id="start">
        <p class="section-label">How it works</p>
        <h2>Write the core resume once, then swap in the details that matter for each role.</h2>
        <p>
          Endless Resume keeps the master version clean and lets you tailor experience, bullets, and
          keywords for every application without rebuilding the document.
        </p>
      </div>
    </section>
  </main>
</Layout>

<script>
  import * as d3 from 'https://cdn.jsdelivr.net/npm/d3@7/+esm';

  // ── Data ──────────────────────────────────────────────────────────────────
  // The sprite sheet is a 3×3 grid — each cell is 1/3 of the image dimensions.
  // We address each avatar by its (col, row) index (0-based).
  type NodeDatum = d3.SimulationNodeDatum & {
    id: number;
    name: string;
    title: string;
    col: number;
    row: number;
    r: number;
  };

  type LinkDatum = d3.SimulationLinkDatum<NodeDatum> & {
    label: string;
  };

  const nodes: NodeDatum[] = [
    { id: 0, name: 'Aisha', title: 'Product Lead', col: 0, row: 0, r: 36 },
    { id: 1, name: 'Rajan', title: 'Full-Stack Eng.', col: 1, row: 0, r: 32 },
    { id: 2, name: 'Mei', title: 'UX Designer', col: 2, row: 0, r: 32 },
    { id: 3, name: 'Carlos', title: 'Data Engineer', col: 0, row: 1, r: 30 },
    { id: 4, name: 'Marcus', title: 'DevOps / Cloud', col: 1, row: 1, r: 34 },
    { id: 5, name: 'Sarah', title: 'Eng. Manager', col: 2, row: 1, r: 30 },
    { id: 6, name: 'Tariq', title: 'ML Engineer', col: 0, row: 2, r: 30 },
    { id: 7, name: 'Emma', title: 'Frontend Dev', col: 1, row: 2, r: 32 },
    { id: 8, name: 'James', title: 'Backend Dev', col: 2, row: 2, r: 30 },
  ];

  const links: LinkDatum[] = [
    { source: 0, target: 1, label: 'Tech lead' },
    { source: 0, target: 2, label: 'Design partner' },
    { source: 0, target: 4, label: 'Cross-func.' },
    { source: 1, target: 3, label: 'Data API' },
    { source: 1, target: 7, label: 'Full-stack' },
    { source: 1, target: 8, label: 'Backend' },
    { source: 2, target: 7, label: 'UI systems' },
    { source: 3, target: 6, label: 'ML pipeline' },
    { source: 4, target: 6, label: 'Infra' },
    { source: 4, target: 8, label: 'Deploy' },
    { source: 5, target: 0, label: 'Reports to' },
    { source: 5, target: 1, label: 'Reports to' },
    { source: 7, target: 8, label: 'Pair prog.' },
  ];

  // ── Setup ─────────────────────────────────────────────────────────────────
  const svg = d3.select<SVGSVGElement, unknown>('#network-svg');
  const wrap = (svg.node() as SVGSVGElement).parentElement!;

  function getSize() {
    return { w: wrap.clientWidth, h: Math.min(wrap.clientWidth * 0.55, 480) };
  }
  let { w, h } = getSize();

  svg.attr('width', w).attr('height', h).style('display', 'block');

  // ── defs: clip paths + image sprite ───────────────────────────────────────
  const defs = svg.append('defs');

  // One shared pattern per node, pointing to a region of the sprite
  const IMG_URL = '/pro-network.jpg';
  // We don't know the image natural size at parse time — we'll read it on load
  const imgEl = new Image();
  imgEl.src = IMG_URL;

  function buildDefs(imgW: number, imgH: number) {
    defs.selectAll('*').remove();

    const cellW = imgW / 3;
    const cellH = imgH / 3;

    nodes.forEach((n) => {
      const d = n.r * 2;
      // clipPath
      defs.append('clipPath').attr('id', `clip-${n.id}`).append('circle').attr('r', n.r);

      // pattern that crops the sprite cell
      defs
        .append('pattern')
        .attr('id', `img-${n.id}`)
        .attr('patternUnits', 'objectBoundingBox')
        .attr('width', 1)
        .attr('height', 1)
        .append('image')
        .attr('href', IMG_URL)
        .attr('width', d * 3) // full sprite scaled to 3× node diameter
        .attr('height', d * 3)
        .attr('x', -(n.col * d)) // shift so correct cell is visible
        .attr('y', -(n.row * d));

      void cellW;
      void cellH; // silence unused-var TS errors
    });
  }

  imgEl.onload = () => buildDefs(imgEl.naturalWidth, imgEl.naturalHeight);
  // Fallback for cached images
  if (imgEl.complete) buildDefs(imgEl.naturalWidth || 1024, imgEl.naturalHeight || 1024);

  // ── Simulation ────────────────────────────────────────────────────────────
  const sim = d3
    .forceSimulation<NodeDatum>(nodes)
    .force(
      'link',
      d3
        .forceLink<NodeDatum, LinkDatum>(links)
        .id((d) => d.id)
        .distance((d) => {
          const s = d.source as NodeDatum;
          const t = d.target as NodeDatum;
          return (s.r + t.r) * 2.4;
        })
    )
    .force('charge', d3.forceManyBody().strength(-280))
    .force('center', d3.forceCenter(w / 2, h / 2))
    .force(
      'collide',
      d3.forceCollide<NodeDatum>((d) => d.r + 10)
    );

  // ── Render layers ─────────────────────────────────────────────────────────
  const linkG = svg.append('g').attr('class', 'links');
  const nodeG = svg.append('g').attr('class', 'nodes');
  const labelG = svg.append('g').attr('class', 'node-labels');

  // Links
  const linkEl = linkG
    .selectAll('line')
    .data(links)
    .enter()
    .append('line')
    .attr('stroke', '#cbd5e1')
    .attr('stroke-width', 1.5)
    .attr('stroke-linecap', 'round');

  // Link labels (middle of each edge)
  const linkLabelEl = linkG
    .selectAll('text')
    .data(links)
    .enter()
    .append('text')
    .attr('class', 'link-label')
    .attr('text-anchor', 'middle')
    .attr('fill', '#94a3b8')
    .attr('font-size', '9')
    .attr('font-family', 'Inter, system-ui, sans-serif')
    .attr('pointer-events', 'none')
    .text((d) => d.label);

  // Node groups
  const nodeEl = nodeG
    .selectAll<SVGGElement, NodeDatum>('g')
    .data(nodes)
    .enter()
    .append('g')
    .attr('class', 'node')
    .style('cursor', 'grab')
    .call(
      d3
        .drag<SVGGElement, NodeDatum>()
        .on('start', (event, d) => {
          if (!event.active) sim.alphaTarget(0.3).restart();
          d.fx = d.x;
          d.fy = d.y;
          d3.select<SVGGElement, NodeDatum>(
            event.sourceEvent.target.closest('.node') as SVGGElement
          ).style('cursor', 'grabbing');
        })
        .on('drag', (event, d) => {
          d.fx = event.x;
          d.fy = event.y;
        })
        .on('end', (event, d) => {
          if (!event.active) sim.alphaTarget(0);
          d.fx = null;
          d.fy = null;
          d3.select<SVGGElement, NodeDatum>(
            event.sourceEvent.target.closest('.node') as SVGGElement
          ).style('cursor', 'grab');
        })
    );

  // Glow ring (hover highlight)
  nodeEl
    .append('circle')
    .attr('class', 'node-ring')
    .attr('r', (d) => d.r + 4)
    .attr('fill', 'none')
    .attr('stroke', '#3b82f6')
    .attr('stroke-width', 2)
    .attr('opacity', 0)
    .attr('transition', 'opacity 180ms');

  // Avatar circle with sprite fill
  nodeEl
    .append('circle')
    .attr('r', (d) => d.r)
    .attr('fill', (d) => `url(#img-${d.id})`)
    .attr('clip-path', (d) => `url(#clip-${d.id})`)
    .attr('stroke', '#ffffff')
    .attr('stroke-width', 3);

  // Hover: show ring
  nodeEl
    .on('mouseenter', function () {
      d3.select(this).select('.node-ring').attr('opacity', 1);
    })
    .on('mouseleave', function () {
      d3.select(this).select('.node-ring').attr('opacity', 0);
    });

  // Name labels below each node
  const nameLabelEl = labelG.selectAll<SVGGElement, NodeDatum>('g').data(nodes).enter().append('g');

  nameLabelEl
    .append('text')
    .attr('class', 'node-name')
    .attr('text-anchor', 'middle')
    .attr('fill', '#0f172a')
    .attr('font-size', '11')
    .attr('font-weight', '700')
    .attr('font-family', 'Inter, system-ui, sans-serif')
    .attr('pointer-events', 'none')
    .text((d) => d.name);

  nameLabelEl
    .append('text')
    .attr('class', 'node-title')
    .attr('text-anchor', 'middle')
    .attr('fill', '#64748b')
    .attr('font-size', '9.5')
    .attr('font-family', 'Inter, system-ui, sans-serif')
    .attr('pointer-events', 'none')
    .text((d) => d.title);

  // ── Tick ──────────────────────────────────────────────────────────────────
  sim.on('tick', () => {
    // Clamp nodes inside canvas
    nodes.forEach((n) => {
      n.x = Math.max(n.r + 10, Math.min(w - n.r - 10, n.x ?? w / 2));
      n.y = Math.max(n.r + 10, Math.min(h - n.r - 10, n.y ?? h / 2));
    });

    linkEl
      .attr('x1', (d) => (d.source as NodeDatum).x!)
      .attr('y1', (d) => (d.source as NodeDatum).y!)
      .attr('x2', (d) => (d.target as NodeDatum).x!)
      .attr('y2', (d) => (d.target as NodeDatum).y!);

    linkLabelEl
      .attr('x', (d) => ((d.source as NodeDatum).x! + (d.target as NodeDatum).x!) / 2)
      .attr('y', (d) => ((d.source as NodeDatum).y! + (d.target as NodeDatum).y!) / 2 - 3);

    nodeEl.attr('transform', (d) => `translate(${d.x},${d.y})`);

    nameLabelEl.attr('transform', (d) => `translate(${d.x},${d.y! + d.r + 14})`);

    nameLabelEl.select('.node-title').attr('y', '11');
  });

  // ── Resize ────────────────────────────────────────────────────────────────
  const ro = new ResizeObserver(() => {
    ({ w, h } = getSize());
    svg.attr('width', w).attr('height', h);
    sim.force('center', d3.forceCenter(w / 2, h / 2));
    sim.alpha(0.3).restart();
  });
  ro.observe(wrap);
</script>

<style>
  .landing {
    display: grid;
    gap: clamp(2rem, 4vw, 4rem);
    padding: 0.5rem 0 2rem;
  }

  /* ── Network section ──────────────────────────────────────────────────── */
  .network-section {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .network-header {
    max-width: 42rem;
  }

  .network-lede {
    margin: 0.6rem 0 0;
    color: #64748b;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .network-canvas-wrap {
    width: 100%;
    border-radius: 1.5rem;
    background: rgb(255 255 255 / 0.6);
    border: 1px solid rgb(148 163 184 / 0.18);
    box-shadow: 0 24px 70px rgb(15 23 42 / 0.07);
    backdrop-filter: blur(14px);
    overflow: hidden;
  }

  /* ── Supporting ───────────────────────────────────────────────────────── */
  .supporting {
    padding: 0 0 1rem;
  }

  .supporting-card {
    max-width: 52rem;
    padding: clamp(1.35rem, 3vw, 2rem);
    border-radius: 1.5rem;
    background: rgb(255 255 255 / 0.72);
    border: 1px solid rgb(148 163 184 / 0.18);
    box-shadow: 0 24px 70px rgb(15 23 42 / 0.08);
    backdrop-filter: blur(14px);
  }

  .section-label {
    margin: 0 0 0.8rem;
    color: #1d4ed8;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .network-header h2,
  .supporting-card h2 {
    margin: 0;
    color: #0f172a;
    font-size: clamp(1.45rem, 3vw, 2.2rem);
    line-height: 1.08;
    letter-spacing: -0.05em;
    text-wrap: balance;
  }

  .supporting-card p {
    margin: 1rem 0 0;
    max-width: 46rem;
    color: #475569;
    font-size: 1rem;
    line-height: 1.7;
  }
</style>
