---
import Layout from '../components/layout/Layout.astro';
import Counter from '../components/counter.tsx';
---

<Layout title="Endless Resume" subtitle="Resume Editor">
  <main class="landing">
    <Counter client:load />
  </main>
</Layout>

<style>
  .landing {
    display: grid;
    place-items: center;
    min-height: calc(100vh - 9rem);
    padding: 2rem 0;
  }
</style>
