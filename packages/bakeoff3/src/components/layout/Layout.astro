---
const { title = 'Endless Resume', subtitle = 'Resume Editor' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <div class="app-shell">
      <header class="site-header">
        <div class="header-inner">
          <div class="brand" aria-label="Endless Resume">
            <span class="brand-mark" aria-hidden="true">ER</span>
            <div class="brand-copy">
              <p class="brand-name">Endless Resume</p>
              <p class="brand-tagline">{subtitle}</p>
            </div>
          </div>
        </div>
      </header>

      <main class="site-main">
        <slot />
      </main>

      <footer class="site-footer">
        <p>Endless Resume</p>
        <p>{subtitle}</p>
      </footer>
    </div>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family: 'Inter', 'Avenir Next', 'Segoe UI', sans-serif;
    background:
      radial-gradient(circle at top left, rgb(59 130 246 / 0.16), transparent 34%),
      radial-gradient(circle at top right, rgb(15 23 42 / 0.08), transparent 28%),
      linear-gradient(180deg, #f8fafc 0%, #eef2f7 48%, #e2e8f0 100%);
    color: #0f172a;
  }

  :global(*) {
    box-sizing: border-box;
  }

  .app-shell {
    min-height: 100vh;
    display: grid;
    grid-template-rows: auto 1fr auto;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    border-bottom: 1px solid rgb(148 163 184 / 0.24);
    background: rgb(255 255 255 / 0.78);
    backdrop-filter: blur(14px);
  }

  .header-inner,
  .site-main,
  .site-footer {
    width: min(1240px, calc(100% - 2rem));
    margin-inline: auto;
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 0;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .brand-mark {
    width: 2.35rem;
    height: 2.35rem;
    border-radius: 0.7rem;
    display: grid;
    place-items: center;
    font-weight: 800;
    letter-spacing: 0.04em;
    color: #ffffff;
    background: linear-gradient(140deg, #0f172a 0%, #1d4ed8 55%, #3b82f6 100%);
    box-shadow: 0 8px 20px rgb(37 99 235 / 0.26);
  }

  .brand-copy {
    display: flex;
    flex-direction: column;
    gap: 0.12rem;
  }

  .brand-name {
    margin: 0;
    font-size: 1.2rem;
    line-height: 1;
    font-weight: 800;
    letter-spacing: 0.01em;
    font-family: 'Avenir Next Condensed', 'Franklin Gothic Medium', 'Arial Narrow', sans-serif;
  }

  .brand-tagline {
    margin: 0;
    font-size: 0.76rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #475569;
    font-weight: 700;
  }

  .site-main {
    padding: 0 0 1.5rem;
  }

  .site-footer {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 0 1.35rem;
    color: #475569;
    font-size: 0.92rem;
  }

  .site-footer p {
    margin: 0;
  }

  @media (max-width: 680px) {
    .header-inner,
    .site-footer {
      flex-direction: column;
      align-items: flex-start;
    }

    .header-inner,
    .site-main,
    .site-footer {
      width: min(1240px, calc(100% - 1rem));
    }
  }
</style>
