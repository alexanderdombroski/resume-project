---
import AuthModal from '../auth/AuthModal.astro';

const { title = 'Endless Resume', subtitle = 'Resume Editor' } = Astro.props;
const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/dashboard', label: 'Dashboard' },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon-64.png" />
    <link rel="icon" type="image/png" sizes="128x128" href="/favicon-128.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <div class="app-shell">
      <header class="site-header">
        <div class="header-inner">
          <a class="brand" href="/" aria-label="Endless Resume home">
            <span class="brand-mark" aria-hidden="true">ER</span>
            <div class="brand-copy">
              <p class="brand-name">Endless Resume</p>
              <p class="brand-tagline">{subtitle}</p>
            </div>
          </a>

          <nav class="site-nav" aria-label="Primary">
            {
              navLinks.map((link) => (
                <a
                  class:list={['nav-link', pathname === link.href && 'is-active']}
                  href={link.href}
                >
                  {link.label}
                </a>
              ))
            }
            <AuthModal />
          </nav>
        </div>
      </header>

      <main class="site-main">
        <slot />
      </main>

      <footer class="site-footer">
        <p>Endless Resume</p>
        <p>{subtitle}</p>
      </footer>
    </div>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family: 'Inter', 'Avenir Next', 'Segoe UI', sans-serif;
    background:
      radial-gradient(circle at top left, rgb(59 130 246 / 0.16), transparent 34%),
      radial-gradient(circle at top right, rgb(15 23 42 / 0.08), transparent 28%),
      linear-gradient(180deg, #f8fafc 0%, #eef2f7 48%, #e2e8f0 100%);
    color: #0f172a;
  }

  :global(*) {
    box-sizing: border-box;
  }

  .app-shell {
    min-height: 100vh;
    display: grid;
    grid-template-rows: auto 1fr auto;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    border-bottom: 1px solid rgb(148 163 184 / 0.24);
    background: #ffffff;
  }

  .header-inner,
  .site-main,
  .site-footer {
    width: min(1240px, calc(100% - 2rem));
    margin-inline: auto;
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 0.95rem 0;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    text-decoration: none;
    color: inherit;
  }

  .site-nav {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    padding: 0.35rem;
    border-radius: 999px;
    background: rgb(255 255 255 / 0.52);
    border: 1px solid rgb(148 163 184 / 0.18);
    box-shadow: 0 10px 30px rgb(15 23 42 / 0.05);
    backdrop-filter: blur(14px);
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.5rem;
    padding: 0.55rem 1rem;
    border-radius: 999px;
    color: #475569;
    text-decoration: none;
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0;
    border: 1px solid transparent;
    position: relative;
    transition:
      background-color 160ms ease,
      border-color 160ms ease,
      color 160ms ease,
      transform 160ms ease,
      box-shadow 160ms ease;
  }

  .nav-link:hover {
    color: #0f172a;
    background: rgb(255 255 255 / 0.78);
    border-color: rgb(148 163 184 / 0.16);
    transform: translateY(-1px);
  }

  .nav-link.is-active {
    color: #0f172a;
    background: linear-gradient(180deg, rgb(255 255 255 / 0.98), rgb(241 245 249 / 0.95));
    border-color: rgb(37 99 235 / 0.16);
    box-shadow: 0 12px 26px rgb(37 99 235 / 0.12);
  }

  .nav-link.is-active::after {
    content: '';
    position: absolute;
    inset: auto 1rem 0.42rem;
    height: 0.18rem;
    border-radius: 999px;
    background: linear-gradient(90deg, #1d4ed8 0%, #60a5fa 100%);
  }

  .brand-mark {
    width: 2.35rem;
    height: 2.35rem;
    border-radius: 0.7rem;
    display: grid;
    place-items: center;
    font-weight: 800;
    letter-spacing: 0.04em;
    color: #ffffff;
    background: linear-gradient(140deg, #0f172a 0%, #1d4ed8 55%, #3b82f6 100%);
    box-shadow: 0 8px 20px rgb(37 99 235 / 0.26);
  }

  .brand-copy {
    display: flex;
    flex-direction: column;
    gap: 0.12rem;
  }

  .brand-name {
    margin: 0;
    font-size: 1.2rem;
    line-height: 1;
    font-weight: 800;
    letter-spacing: 0.01em;
    font-family: 'Avenir Next Condensed', 'Franklin Gothic Medium', 'Arial Narrow', sans-serif;
  }

  .brand-tagline {
    margin: 0;
    font-size: 0.76rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #475569;
    font-weight: 700;
  }

  .site-main {
    padding: 0 0 1.5rem;
  }

  .site-footer {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 0 1.35rem;
    color: #475569;
    font-size: 0.92rem;
  }

  .site-footer p {
    margin: 0;
  }

  @media (max-width: 680px) {
    .header-inner,
    .site-footer {
      flex-direction: column;
      align-items: flex-start;
    }

    .site-nav {
      margin-left: 0;
      width: 100%;
      justify-content: flex-start;
      overflow-x: auto;
      scrollbar-width: none;
    }

    .site-nav::-webkit-scrollbar {
      display: none;
    }

    .nav-link {
      white-space: nowrap;
    }

    .header-inner,
    .site-main,
    .site-footer {
      width: min(1240px, calc(100% - 1rem));
    }
  }
</style>
