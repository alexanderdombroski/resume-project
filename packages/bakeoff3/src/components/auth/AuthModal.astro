---
import { Show, SignIn, UserButton } from '@clerk/astro/components';
---

<div class="auth-slot">
  <Show when="signed-out">
    <button
      class="nav-link auth-trigger"
      type="button"
      aria-haspopup="dialog"
      aria-controls="auth-dialog"
      data-auth-open
    >
      Sign in / Register
    </button>

    <dialog class="auth-dialog" id="auth-dialog" aria-labelledby="auth-title" data-auth-dialog>
      <div class="auth-dialog-shell">
        <button
          class="auth-close"
          type="button"
          aria-label="Close authentication modal"
          data-auth-close
        >
          x
        </button>

        <div class="auth-copy">
          <p class="auth-label">Account access</p>
          <h2 id="auth-title">Sign in or create an account</h2>
          <p>
            Use your username or email and password to enter the workspace. Register a new account
            from the same form when needed.
          </p>
        </div>

        <div class="auth-form">
          <SignIn
            withSignUp={true}
            fallbackRedirectUrl="/dashboard"
            signUpFallbackRedirectUrl="/dashboard"
          />
        </div>
      </div>
    </dialog>
  </Show>

  <Show when="signed-in">
    <div class="auth-user">
      <UserButton showName />
    </div>
  </Show>
</div>

<script is:inline>
  const dialog = document.querySelector('[data-auth-dialog]');
  const openButton = document.querySelector('[data-auth-open]');
  const closeButton = document.querySelector('[data-auth-close]');

  if (dialog instanceof HTMLDialogElement && openButton instanceof HTMLButtonElement) {
    openButton.addEventListener('click', () => {
      dialog.showModal();
    });
  }

  if (dialog instanceof HTMLDialogElement && closeButton instanceof HTMLButtonElement) {
    closeButton.addEventListener('click', () => {
      dialog.close();
    });
  }

  if (dialog instanceof HTMLDialogElement) {
    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) {
        dialog.close();
      }
    });
  }
</script>

<style>
  .auth-slot {
    margin-left: auto;
    display: flex;
    align-items: center;
  }

  .auth-trigger {
    appearance: none;
    background: transparent;
    border: 1px solid transparent;
    cursor: pointer;
  }

  .auth-user {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  .auth-dialog {
    width: min(40rem, calc(100vw - 1.25rem));
    padding: 0;
    border: none;
    border-radius: 1.4rem;
    background: transparent;
    box-shadow: none;
  }

  .auth-dialog::backdrop {
    background: rgb(15 23 42 / 0.56);
    backdrop-filter: blur(8px);
  }

  .auth-dialog-shell {
    position: relative;
    display: grid;
    gap: 1.15rem;
    padding: clamp(1.1rem, 2vw, 1.5rem);
    border-radius: 1.4rem;
    background: linear-gradient(180deg, rgb(255 255 255 / 0.98), rgb(241 245 249 / 0.98));
    border: 1px solid rgb(148 163 184 / 0.18);
    box-shadow: 0 28px 70px rgb(15 23 42 / 0.22);
  }

  .auth-close {
    position: absolute;
    top: 0.85rem;
    right: 0.95rem;
    width: 2.25rem;
    height: 2.25rem;
    border: none;
    border-radius: 999px;
    background: rgb(15 23 42 / 0.06);
    color: #0f172a;
    font-size: 1.35rem;
    line-height: 1;
    cursor: pointer;
  }

  .auth-copy {
    max-width: 28rem;
    padding-right: 2.5rem;
  }

  .auth-label {
    margin: 0 0 0.45rem;
    color: #1d4ed8;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .auth-copy h2 {
    margin: 0;
    color: #0f172a;
    font-size: clamp(1.4rem, 3vw, 2rem);
    line-height: 1.08;
    letter-spacing: -0.05em;
    text-wrap: balance;
  }

  .auth-copy p:last-child {
    margin: 0.85rem 0 0;
    color: #475569;
    line-height: 1.65;
  }

  .auth-form :global(form) {
    width: 100%;
  }

  @media (max-width: 680px) {
    .auth-slot {
      margin-left: 0;
      width: 100%;
    }

    .auth-user {
      width: 100%;
      justify-content: space-between;
      flex-wrap: wrap;
    }

    .auth-dialog {
      width: calc(100vw - 0.75rem);
    }
  }
</style>
