---
// All auth is handled client-side via @clerk/clerk-js — no server-side imports needed.
---

<div class="auth-slot" id="auth-slot">
  <!-- Signed-out: trigger button + dialog -->
  <div id="auth-signed-out" hidden>
    <button
      class="nav-link auth-trigger"
      type="button"
      aria-haspopup="dialog"
      aria-controls="auth-dialog"
      id="auth-open-btn"
    >
      Sign in / Register
    </button>

    <dialog class="auth-dialog" id="auth-dialog" aria-labelledby="auth-title">
      <div class="auth-dialog-shell">
        <button
          class="auth-close"
          type="button"
          aria-label="Close authentication modal"
          id="auth-close-btn"
        >
          x
        </button>

        <div class="auth-copy">
          <p class="auth-label">Account access</p>
          <h2 id="auth-title">Sign in or create an account</h2>
          <p>
            Use your username or email and password to enter the workspace. Register a new account
            from the same form when needed.
          </p>
        </div>

        <!-- Clerk mounts SignIn here -->
        <div class="auth-form" id="clerk-sign-in"></div>
      </div>
    </dialog>
  </div>

  <!-- Signed-in: UserButton -->
  <div class="auth-user" id="auth-signed-in" hidden>
    <!-- Clerk mounts UserButton here -->
    <div id="clerk-user-button"></div>
  </div>
</div>

<script>
  import { Clerk } from '@clerk/clerk-js';

  const publishableKey = import.meta.env.PUBLIC_CLERK_PUBLISHABLE_KEY;

  if (!publishableKey) {
    throw new Error('Add PUBLIC_CLERK_PUBLISHABLE_KEY to your .env file');
  }

  // Derive the Frontend API domain from the publishable key
  const clerkDomain = atob(publishableKey.split('_')[2]).slice(0, -1);

  // Load the Clerk UI bundle from Clerk's own CDN (separate from the core JS)
  await new Promise<void>((resolve, reject) => {
    const script = document.createElement('script');
    script.src = `https://${clerkDomain}/npm/@clerk/ui@1/dist/ui.browser.js`;
    script.async = true;
    script.crossOrigin = 'anonymous';
    script.onload = () => resolve();
    script.onerror = () => reject(new Error('Failed to load @clerk/ui bundle'));
    document.head.appendChild(script);
  });

  const clerk = new Clerk(publishableKey);
  await clerk.load({
    ui: { ClerkUI: (window as any).__internal_ClerkUICtor },
  });

  // ---------- DOM refs ----------

  const signedOutEl = document.getElementById('auth-signed-out')!;
  const signedInEl = document.getElementById('auth-signed-in')!;
  const dialog = document.getElementById('auth-dialog') as HTMLDialogElement;
  const openBtn = document.getElementById('auth-open-btn') as HTMLButtonElement;
  const closeBtn = document.getElementById('auth-close-btn') as HTMLButtonElement;
  const signInMount = document.getElementById('clerk-sign-in')!;
  const ubMount = document.getElementById('clerk-user-button')!;

  const shouldOpenAuth = new URLSearchParams(window.location.search).get('auth') === 'sign-in';

  let signInMounted = false;
  let ubMounted = false;

  // ---------- Helpers ----------

  function clearAuthParam() {
    const url = new URL(window.location.href);
    if (!url.searchParams.has('auth')) return;
    url.searchParams.delete('auth');
    window.history.replaceState({}, '', url.pathname + url.search + url.hash);
  }

  function openDialog() {
    if (!dialog.open) dialog.showModal();
  }

  function mountSignIn() {
    if (signInMounted) return;
    clerk.mountSignIn(signInMount, {
      fallbackRedirectUrl: '/dashboard',
      signUpFallbackRedirectUrl: '/dashboard',
    });
    signInMounted = true;
  }

  // ---------- Auth state ----------

  function applyAuthState() {
    if (clerk.user) {
      signedOutEl.hidden = true;
      signedInEl.hidden = false;

      if (dialog.open) dialog.close();

      if (!ubMounted) {
        clerk.mountUserButton(ubMount, { showName: true });
        ubMounted = true;
      }
      if (signInMounted) {
        clerk.unmountSignIn(signInMount);
        signInMounted = false;
      }
    } else {
      signedOutEl.hidden = false;
      signedInEl.hidden = true;

      if (ubMounted) {
        clerk.unmountUserButton(ubMount);
        ubMounted = false;
      }
    }
  }

  // ---------- Event wiring ----------

  openBtn.addEventListener('click', () => {
    openDialog();
    mountSignIn();
  });

  closeBtn.addEventListener('click', () => {
    dialog.close();
    clearAuthParam();
  });

  dialog.addEventListener('click', (e) => {
    if (e.target === dialog) dialog.close();
  });

  dialog.addEventListener('close', clearAuthParam);

  clerk.addListener(applyAuthState);
  applyAuthState();

  if (shouldOpenAuth && !clerk.user) {
    openDialog();
    mountSignIn();
  }
</script>

<style>
  .auth-slot {
    margin-left: auto;
    display: flex;
    align-items: center;
  }

  #auth-signed-out,
  #auth-signed-in {
    display: contents;
  }

  #auth-signed-out[hidden],
  #auth-signed-in[hidden] {
    display: none;
  }

  .auth-trigger {
    appearance: none;
    background: transparent;
    border: 1px solid transparent;
    cursor: pointer;
  }

  .auth-user {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  .auth-dialog {
    width: min(40rem, calc(100vw - 1.25rem));
    padding: 0;
    border: none;
    border-radius: 1.4rem;
    background: transparent;
    box-shadow: none;
  }

  .auth-dialog::backdrop {
    background: rgb(15 23 42 / 0.56);
    backdrop-filter: blur(8px);
  }

  .auth-dialog-shell {
    position: relative;
    display: grid;
    gap: 1.15rem;
    padding: clamp(1.1rem, 2vw, 1.5rem);
    border-radius: 1.4rem;
    background: linear-gradient(180deg, rgb(255 255 255 / 0.98), rgb(241 245 249 / 0.98));
    border: 1px solid rgb(148 163 184 / 0.18);
    box-shadow: 0 28px 70px rgb(15 23 42 / 0.22);
  }

  .auth-close {
    position: absolute;
    top: 0.85rem;
    right: 0.95rem;
    width: 2.25rem;
    height: 2.25rem;
    border: none;
    border-radius: 999px;
    background: rgb(15 23 42 / 0.06);
    color: #0f172a;
    font-size: 1.35rem;
    line-height: 1;
    cursor: pointer;
  }

  .auth-copy {
    max-width: 28rem;
    padding-right: 2.5rem;
  }

  .auth-label {
    margin: 0 0 0.45rem;
    color: #1d4ed8;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .auth-copy h2 {
    margin: 0;
    color: #0f172a;
    font-size: clamp(1.4rem, 3vw, 2rem);
    line-height: 1.08;
    letter-spacing: -0.05em;
    text-wrap: balance;
  }

  .auth-copy p:last-child {
    margin: 0.85rem 0 0;
    color: #475569;
    line-height: 1.65;
  }

  @media (max-width: 680px) {
    .auth-slot {
      margin-left: 0;
      width: 100%;
    }

    .auth-user {
      width: 100%;
      justify-content: space-between;
      flex-wrap: wrap;
    }

    .auth-dialog {
      width: calc(100vw - 0.75rem);
    }
  }
</style>
