---
const primaryStats = [
  { label: 'One master resume', value: '01' },
  { label: 'Tailored versions', value: '∞' },
  { label: 'Faster applications', value: '2x' },
];
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero-copy">
    <p class="eyebrow">Resume builder for focused job searches</p>
    <h1 id="hero-title">
      Endless Resume
      <span>Build once, tailor forever.</span>
    </h1>
    <p class="lede">
      Keep one strong source resume, then generate role-specific versions without redoing the entire
      document every time a posting changes.
    </p>

    <div class="actions">
      <a class="button button-primary" href="#start">Start your resume</a>
      <a class="button button-secondary" href="#how-it-works">See how it works</a>
    </div>

    <dl class="stats" aria-label="Product highlights">
      {
        primaryStats.map((stat) => (
          <div class="stat">
            <dt>{stat.label}</dt>
            <dd>{stat.value}</dd>
          </div>
        ))
      }
    </dl>
  </div>

  <div class="hero-visual" aria-hidden="true">
    <div class="glow glow-left"></div>
    <div class="glow glow-right"></div>

    <div class="mockup master">
      <p class="card-label">Master resume</p>
      <h2>Strategic product designer</h2>
      <ul>
        <li>Led redesigns across consumer and B2B products</li>
        <li>Built a reusable content system for 12 launches</li>
        <li>Cut handoff time by 35% with tighter workflows</li>
      </ul>
    </div>

    <div class="mockup tailored">
      <p class="card-label">Tailored version</p>
      <h2>Senior product designer, AI tools</h2>
      <ul>
        <li>Emphasized prompt workflows and experimentation</li>
        <li>Reordered impact bullets around product metrics</li>
        <li>Matched language to the target job description</li>
      </ul>
    </div>

    <div class="floating-chip chip-top">ATS-aware edits</div>
    <div class="floating-chip chip-bottom">Version control included</div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
    gap: clamp(2rem, 4vw, 4.5rem);
    align-items: center;
    min-height: calc(100vh - 10rem);
    padding: clamp(2rem, 4vw, 4rem) 0;
  }

  .hero-copy {
    position: relative;
    z-index: 1;
    max-width: 42rem;
  }

  .eyebrow {
    margin: 0 0 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    background: rgb(15 23 42 / 0.06);
    color: #0f172a;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(3.1rem, 7vw, 6.2rem);
    line-height: 0.96;
    letter-spacing: -0.06em;
    color: #0f172a;
    text-wrap: balance;
  }

  h1 span {
    display: block;
    margin-top: 0.8rem;
    font-size: clamp(1.1rem, 2vw, 1.55rem);
    line-height: 1.35;
    letter-spacing: -0.02em;
    color: #334155;
    font-weight: 600;
  }

  .lede {
    margin: 1.4rem 0 0;
    max-width: 34rem;
    font-size: 1.06rem;
    line-height: 1.7;
    color: #475569;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.15rem;
    padding: 0.85rem 1.25rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    letter-spacing: -0.01em;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease,
      background-color 160ms ease;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button-primary {
    color: #ffffff;
    background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 55%, #2563eb 100%);
    box-shadow: 0 18px 34px rgb(37 99 235 / 0.28);
  }

  .button-secondary {
    color: #0f172a;
    background: rgb(255 255 255 / 0.72);
    border: 1px solid rgb(148 163 184 / 0.35);
    backdrop-filter: blur(12px);
  }

  .stats {
    margin: 2.1rem 0 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .stat {
    padding: 1rem 1rem 0.95rem;
    border-radius: 1.15rem;
    background: rgb(255 255 255 / 0.7);
    border: 1px solid rgb(148 163 184 / 0.2);
    box-shadow: 0 18px 50px rgb(15 23 42 / 0.06);
    backdrop-filter: blur(14px);
  }

  .stat dt {
    margin: 0;
    color: #64748b;
    font-size: 0.82rem;
    line-height: 1.35;
  }

  .stat dd {
    margin: 0.45rem 0 0;
    color: #0f172a;
    font-size: 1.4rem;
    line-height: 1;
    letter-spacing: -0.04em;
    font-weight: 800;
  }

  .hero-visual {
    position: relative;
    min-height: 34rem;
    display: grid;
    place-items: center;
  }

  .glow {
    position: absolute;
    inset: auto;
    border-radius: 999px;
    filter: blur(48px);
    opacity: 0.9;
  }

  .glow-left {
    width: 16rem;
    height: 16rem;
    top: 1rem;
    left: 1rem;
    background: rgb(59 130 246 / 0.26);
  }

  .glow-right {
    width: 18rem;
    height: 18rem;
    right: 0;
    bottom: 0;
    background: rgb(15 23 42 / 0.12);
  }

  .mockup {
    position: absolute;
    width: min(28rem, 90%);
    padding: 1.35rem;
    border-radius: 1.6rem;
    background: linear-gradient(180deg, rgb(255 255 255 / 0.92), rgb(241 245 249 / 0.9));
    border: 1px solid rgb(148 163 184 / 0.22);
    box-shadow: 0 28px 70px rgb(15 23 42 / 0.14);
    backdrop-filter: blur(16px);
  }

  .mockup::before {
    content: '';
    display: block;
    width: 4.5rem;
    height: 0.5rem;
    margin-bottom: 1rem;
    border-radius: 999px;
    background: linear-gradient(90deg, #cbd5e1 0%, #94a3b8 100%);
  }

  .master {
    transform: translate(-1.5rem, -2rem) rotate(-7deg);
  }

  .tailored {
    transform: translate(2.6rem, 4.4rem) rotate(8deg);
    background: linear-gradient(180deg, rgb(239 246 255 / 0.96), rgb(255 255 255 / 0.94));
  }

  .card-label {
    margin: 0 0 0.35rem;
    color: #2563eb;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .mockup h2 {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.1;
    letter-spacing: -0.04em;
    color: #0f172a;
  }

  .mockup ul {
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.75rem;
    color: #334155;
    line-height: 1.5;
  }

  .mockup li {
    position: relative;
    padding-left: 1rem;
  }

  .mockup li::before {
    content: '';
    position: absolute;
    top: 0.62rem;
    left: 0;
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #1d4ed8 0%, #60a5fa 100%);
  }

  .floating-chip {
    position: absolute;
    padding: 0.65rem 0.95rem;
    border-radius: 999px;
    background: rgb(255 255 255 / 0.88);
    border: 1px solid rgb(148 163 184 / 0.24);
    box-shadow: 0 16px 40px rgb(15 23 42 / 0.1);
    color: #0f172a;
    font-size: 0.85rem;
    font-weight: 700;
    backdrop-filter: blur(12px);
  }

  .chip-top {
    top: 0.5rem;
    right: 1rem;
  }

  .chip-bottom {
    left: 0.75rem;
    bottom: 1rem;
  }

  @media (max-width: 980px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
      padding-bottom: 2rem;
    }

    .hero-visual {
      min-height: 30rem;
      order: -1;
    }
  }

  @media (max-width: 680px) {
    h1 {
      font-size: clamp(2.8rem, 16vw, 4.5rem);
    }

    .stats {
      grid-template-columns: 1fr;
    }

    .hero-visual {
      min-height: 24rem;
    }

    .mockup {
      width: min(24rem, 92%);
    }

    .master {
      transform: translate(-0.6rem, -1.25rem) rotate(-5deg);
    }

    .tailored {
      transform: translate(0.8rem, 4rem) rotate(6deg);
    }
  }
</style>
