erDiagram

USER {
    int id
    string email
    string passwordHash
}

RESUME {
    int id
    string userId
    string title
    string summary
    datetime createdAt
    datetime updatedAt
}

SECTION {
    int id
    string resumeId
    string title
    int order
    string type
}

BULLET_POINT {
    int id
    string sectionId
    string content
    int order
}

SECTION_ITEM {
    int id
    string sectionId
    string label
    string value
    date startDate
    date endDate
    string location
    string description
    int order
}

%% Relationships
USER ||--o{ RESUME : owns
RESUME ||--o{ SECTION : contains
SECTION ||--o{ BULLET_POINT : has
SECTION ||--o{ SECTION_ITEM : has